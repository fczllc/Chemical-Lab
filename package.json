{
  "name": "element-explorer-kids",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:local": "node scripts/deploy-local.mjs",
    "validate:elements": "node scripts/validate-elements.mjs",
    "validate:supporting": "node scripts/validate-supporting-data.mjs",
    "validate:spectral": "node scripts/validate-spectral-lines.mjs",
    "validate:curriculum": "node scripts/validate-curriculum.mjs",
    "validate:textbook-assets": "node scripts/validate-textbook-assets.mjs",
    "validate:textbook-batch": "node scripts/textbook/validate-batch-contract.mjs",
    "validate:textbook-drafts": "node scripts/textbook/validate-draft-schema.mjs",
    "validate:textbook-experiments": "node scripts/textbook/validate-experiment-backlog.mjs",
    "validate:textbook-enrichment": "node scripts/textbook/validate-enrichment-fixtures.mjs",
    "textbook:extract": "node scripts/textbook/extract-textbook.mjs",
    "textbook:generate-drafts": "node scripts/textbook/generate-drafts.mjs",
    "textbook:coverage": "node scripts/textbook/generate-coverage.mjs",
    "textbook:inventory": "node scripts/textbook/inventory-processed-volumes.mjs",
    "textbook:promote": "node scripts/textbook/promote-topic.mjs",
    "validate:textbook-runtime-boundary": "node scripts/textbook/validate-runtime-boundary.mjs && node scripts/textbook/validate-runtime-integrity.mjs",
    "validate:textbook-workflow": "node scripts/textbook/validate-workflow.mjs",
    "validate:all:safe": "npm run validate:elements && npm run validate:supporting && node scripts/validate-quiz-data.mjs && npm run validate:spectral && npm run validate:curriculum && npm run validate:textbook-assets && npm run validate:textbook-runtime-boundary && npm run validate:textbook-workflow -- --all-reviewed && node scripts/audit-business-data-imports.mjs && npm run build",
    "validate:data": "npm run validate:elements && npm run validate:story-media && npm run validate:supporting && npm run validate:spectral && node scripts/audit-business-data-imports.mjs",
    "validate:story-media": "node scripts/validate-story-media.mjs",
    "validate:chem-notation": "node scripts/validate-chem-notation.mjs",
    "validate:textbook-coverage": "node scripts/textbook/validate-coverage.mjs",
    "validate:textbook-reactions": "node scripts/textbook/validate-reaction-extraction.mjs",
    "validate:reaction-game-pool": "node scripts/validate-reaction-game-pool.mjs",
    "validate:lab-experiments": "node scripts/validate-lab-experiments.mjs",
    "validate:lab-boundary": "node scripts/validate-lab-data-boundary.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "sharp": "^0.34.5",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "gsap": "^3.12.7",
    "katex": "^0.16.45",
    "lottie-web": "^5.13.0",
    "lucide": "^1.14.0",
    "three": "^0.184.0"
  }
}
